{
  "expo": {
    "name": "PropEdge Agent",
    "slug": "propedge-mobile-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.propedge.agent",
      "permissions": ["RECORD_AUDIO", "MODIFY_AUDIO_SETTINGS"]
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Allow PropEdge Agent to access your microphone to talk to leads."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "58214714-da16-41e6-9977-b6108048af7a"
      }
    }
  }
}
